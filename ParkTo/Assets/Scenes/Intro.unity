  m_Script: {fileID: 11500000, guid: 54d60b82f70a8f943a265871c450d38a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  helpImages:
  - {fileID: 21300000, guid: f313a6aa5ddcfa943a5523c36b28f8b2, type: 3}
  - {fileID: 21300000, guid: e0a3a84623257b24bb6ede7175b6f1dc, type: 3}
  - {fileID: 21300000, guid: be54af81a4648b04aa5fc38b866853dc, type: 3}
  - {fileID: 21300000, guid: bdb98ba295fa656489665b6560e28b77, type: 3}
  - {fileID: 21300000, guid: 06454c7062e8d6847bc5cad07873b0b4, type: 3}
  - {fileID: 21300000, guid: 5c199faa92015e24f9f4de1a76de1880, type: 3}
  - {fileID: 21300000, guid: 2c54baa29caff4f43b05e6e4a0ac64c3, type: 3}
  helpTexts:
  - "1. \uCC28\uB97C \uC120\uD0DD\uD558\uAC70\uB098 \uC2A4\uD398\uC774\uC2A4\uBC14\uB97C
    \uB204\uB974\uBA74 \uC2DC\uC791\uD569\uB2C8\uB2E4.\n2. \uC88C/\uC6B0, A/D \uD0A4\uB97C
    \uB204\uB974\uAC70\uB098 \uD074\uB9AD\uC744 \uD1B5\uD574 \uB2E8\uACC4\uB97C \uC120\uD0DD\uD569\uB2C8\uB2E4.\n3.
    \uB9F5\uC744 \uBCC0\uACBD\uD569\uB2C8\uB2E4."
  - "1. \uBAA8\uB4E0 \uB3C4\uCC29 \uD2B8\uB9AC\uAC70\uC5D0 \uAC19\uC740 \uC0C9\uC758
    \uCC28\uAC00 \uC815\uC9C0\uD558\uBA74 \uC131\uACF5\uC785\uB2C8\uB2E4.\r\n2. \uC7AC\uC0DD
    \uBC84\uD2BC\uC744 \uB20C\uB7EC \uCC28\uB97C \uC6C0\uC9C1\uC77C \uC218 \uC788\uC2B5\uB2C8\uB2E4.\r\n3.
    Undo \uBC84\uD2BC\uC744 \uB204\uB974\uAC70\uB098 Z\uD0A4\uB97C \uD1B5\uD574 \uB418\uB3CC\uB9B4
    \uC218 \uC788\uC2B5\uB2C8\uB2E4.\r\n4. \uCD08\uAE30\uD654 \uBC84\uD2BC\uC744
    \uB204\uB974\uAC70\uB098 R\uD0A4\uB97C \uD1B5\uD574 \uB2E8\uACC4\uB97C \uB2E4\uC2DC
    \uC2DC\uC791\uD569\uB2C8\uB2E4."
  - "\uD2B8\uB9AC\uAC70\uB97C \uC120\uD0DD\uD558\uC5EC \uD0C0\uC77C\uC5D0 \uC124\uCE58\uD560
    \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n1. \uC6B0\uD68C\uC804 \uD2B8\uB9AC\uAC70\uB294
    \uCC28\uB97C \uC6B0\uD68C\uC804 \uC2DC\uD0B5\uB2C8\uB2E4."
  - "\uD2B8\uB9AC\uAC70 \uC120\uD0DD \uC0C1\uD0DC\uC5D0\uC11C \uB9C8\uC6B0\uC2A4
    \uC624\uB978\uCABD \uBC84\uD2BC\uC744 \uB204\uB974\uBA74 \uCC28\uB97C \uC120\uD0DD\uD560
    \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n1. \uC88C\uD68C\uC804 \uD2B8\uB9AC\uAC70\uB294
    \uCC28\uB97C \uC88C\uD68C\uC804 \uC2DC\uD0B5\uB2C8\uB2E4."
  - "1. \uC815\uC9C0 \uD2B8\uB9AC\uAC70\uB294 \uCC28\uB97C \uC815\uC9C0\uC2DC\uD0B5\uB2C8\uB2E4."
  - "1.  \uD6C4\uC9C4 \uD2B8\uB9AC\uAC70\uB294 \uCC28\uB97C \uD6C4\uC9C4\uC2DC\uD0B5\uB2C8\uB2E4."
  - "1. \uD0C0\uC77C\uC5D0 X\uD45C\uC2DC\uAC00 \uC788\uB294 \uACBD\uC6B0 \uD574\uB2F9
    \uD0C0\uC77C\uC5D0 \uD2B8\uB9AC\uAC70\uB97C \uC124\uCE58\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
